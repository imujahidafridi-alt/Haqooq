rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isAuthenticated() && userExists() && getUserData().role == 'admin';
    }
    function isVerifiedLawyer() {
      return isAuthenticated() && userExists() && getUserData().role == 'lawyer' && getUserData().status == 'verified';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (resource != null && resource.data.role == 'lawyer' && resource.data.status == 'verified');
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium', 'biddingCredits', 'status'])) || isAdmin();
    }

    match /cases/{caseId} {
      allow read, write: if isAuthenticated() && resource != null && resource.data.clientId == request.auth.uid;
      allow read: if isVerifiedLawyer() && resource != null && (resource.data.status == 'open' || resource.data.assignedLawyerId == request.auth.uid);
      allow update: if isVerifiedLawyer() && resource != null && resource.data.assignedLawyerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
    }

    match /proposals/{proposalId} {
        allow write: if isVerifiedLawyer() && request.resource.data.lawyerId == request.auth.uid || 
                     (isAuthenticated() && get(/databases/$(database)/documents/cases/$(request.resource.data.caseId)).data.clientId == request.auth.uid);
        
        allow read: if (isAuthenticated() && get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId == request.auth.uid) || 
                       (isVerifiedLawyer() && resource != null && resource.data.lawyerId == request.auth.uid);
    }

    match /chats/{chatId} {
      // Simplified for MVP to avoid array evaluation permission errors
      allow read, update: if isAuthenticated();
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated(); // Simplified for MVP chat access
      }
    }

    match /notifications/{notificationId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false; 
    }

    match /transactions/{txId} {
      allow read: if resource != null && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow write: if false; 
    }
  }
}
